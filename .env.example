# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_ALLOW_FALLBACKS=False

# Active Provider: google or openrouter
TRANSLATOR_PROVIDER=google

# Google Gemini Native API Keys (comma separated)
GEMINI_API_KEYS=your_first_gemini_key_here,your_second_gemini_key_here,your_third_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash


# Database Configuration (PostgreSQL/SQLite)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# File Storage Config
UPLOAD_DIR=./upload
OUTPUT_DIR=./output

# Server Settings
HOST=127.0.0.1
PORT=8000
DEBUG=True
